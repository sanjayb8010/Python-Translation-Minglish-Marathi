# Copy to .env and fill with your secrets (never commit .env).

# Azure AD (optional unless you extend with Entra-secured resources)
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
SG_GROUP=

# Azure OpenAI (required for POST /translate)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Output style / task mode are fixed in app.py (minglish + auto).

# Optional: sampler temperature — used only when the deployment accepts it (gpt-5 / o-series use API default automatically).
AZURE_OPENAI_TEMPERATURE=0.2

SUGGEST_MAX_COMPLETION_TOKENS=200

# GPT-5 / o-series: higher budgets can improve difficult prompts but increase latency.
# Keep these low for word-by-word/live typing UX; increase only if you see empty-content responses.
TRANSLATE_MIN_COMPLETION_TOKENS=512
SUGGEST_MIN_COMPLETION_TOKENS=256
TRANSLATE_ABSOLUTE_COMPLETION_CAP=32000

# off|minimal|low|medium|high — keep OFF for fastest live translation.
AZURE_OPENAI_REASONING_EFFORT=off

# low|medium|high — omit to use default verbosity=low on reasoning models (fewer tokens / usually faster output)
AZURE_OPENAI_VERBOSITY=

# Repeat identical translations (same deployment + exact text + style + mode) are served from memory (no Azure round-trip).
TRANSLATE_CACHE_MAX=400

# Set to 1 if your deployment rejects default verbosity injection.
# AZURE_OPENAI_DISABLE_DEFAULT_VERBOSITY=1

# Local debugging: put the real Azure/OpenAI error text in JSON + server logs when requests fail (do not expose in prod).
# AZURE_OPENAI_VERBOSE_ERRORS=1

# Server
PORT=5000
